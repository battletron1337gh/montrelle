{% comment %}
  Featured Collection - Maison Fierce Style
  Modern product grid with hover effects
{% endcomment %}

<section class="featured-collection" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="collection-header">
      <h2 class="collection-header__title">{{ section.settings.title | escape }}</h2>
      {%- if section.settings.show_view_all and section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}" class="collection-header__link">
          {{ 'sections.featured_collection.view_all' | t | default: 'Tout' }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <div class="collection-grid" data-columns="{{ section.settings.columns_desktop }}">
      {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
        <article class="product-card" data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 100 }}">
          <a href="{{ product.url }}" class="product-card__link">
            <div class="product-card__image-wrapper">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 800 }}"
                     alt="{{ product.featured_image.alt | escape }}"
                     class="product-card__image product-card__image--primary"
                     loading="lazy"
                     width="600"
                     height="800">
                {%- if product.images[1] -%}
                  <img src="{{ product.images[1] | image_url: width: 800 }}"
                       alt="{{ product.images[1].alt | escape }}"
                       class="product-card__image product-card__image--hover"
                       loading="lazy"
                       width="600"
                       height="800">
                {%- endif -%}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'product-card__image product-card__image--placeholder' }}
              {%- endif -%}
              
              <div class="product-card__overlay">
                <span class="product-card__quick-view">Voir le produit</span>
              </div>
              
              {%- if product.compare_at_price > product.price -%}
                <span class="product-card__badge product-card__badge--sale">-{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</span>
              {%- elsif product.tags contains 'new' -%}
                <span class="product-card__badge product-card__badge--new">Nouveau</span>
              {%- endif -%}
            </div>
            
            <div class="product-card__info">
              <h3 class="product-card__title">{{ product.title }}</h3>
              <div class="product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="product-card__price-current">{{ product.price | money }}</span>
                  <s class="product-card__price-compare">{{ product.compare_at_price | money }}</s>
                {%- else -%}
                  <span class="product-card__price-current">{{ product.price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </a>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .featured-collection {
    padding: 8rem 0;
    background: var(--color-background);
  }
  
  .page-width {
    max-width: 140rem;
    margin: 0 auto;
    padding: 0 3rem;
  }
  
  .collection-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4rem;
  }
  
  .collection-header__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2.4rem, 4vw, 3.2rem);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin: 0;
  }
  
  .collection-header__link {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--color-text);
    text-decoration: none;
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    position: relative;
    transition: color 0.3s ease;
  }
  
  .collection-header__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: currentColor;
    transition: width 0.3s ease;
  }
  
  .collection-header__link:hover::after {
    width: 100%;
  }
  
  .collection-header__link:hover {
    color: var(--color-accent);
  }
  
  .collection-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: repeat(2, 1fr);
  }
  
  @media screen and (min-width: 750px) {
    .collection-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  @media screen and (min-width: 990px) {
    .collection-grid[data-columns="4"] {
      grid-template-columns: repeat(4, 1fr);
    }
    .collection-grid[data-columns="3"] {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  /* Product Card */
  .product-card {
    position: relative;
  }
  
  .product-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  
  .product-card__image-wrapper {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #f5f5f5;
    margin-bottom: 1.5rem;
  }
  
  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
  }
  
  .product-card__image--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  
  .product-card:hover .product-card__image--primary {
    opacity: 0;
  }
  
  .product-card:hover .product-card__image--hover {
    opacity: 1;
    transform: scale(1.03);
  }
  
  .product-card:hover .product-card__image--primary {
    transform: scale(1.03);
  }
  
  .product-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  
  .product-card:hover .product-card__overlay {
    opacity: 1;
  }
  
  .product-card__quick-view {
    background: #fff;
    color: #0a0a0a;
    padding: 1.2rem 2.5rem;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transform: translateY(20px);
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .product-card:hover .product-card__quick-view {
    transform: translateY(0);
    opacity: 1;
  }
  
  .product-card__badge {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    padding: 0.5rem 1.2rem;
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
  }
  
  .product-card__badge--sale {
    background: #c41e3a;
    color: #fff;
  }
  
  .product-card__badge--new {
    background: #0a0a0a;
    color: #fff;
  }
  
  .product-card__info {
    text-align: center;
  }
  
  .product-card__title {
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0 0 0.8rem;
    line-height: 1.4;
  }
  
  .product-card__price {
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  
  .product-card__price-current {
    font-weight: 500;
  }
  
  .product-card__price-compare {
    color: var(--color-text);
    opacity: 0.5;
    text-decoration: line-through;
  }
  
  /* Scroll animations */
  [data-aos] {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  
  [data-aos].aos-animate {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Simple intersection observer for scroll animations
  document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('aos-animate');
        }
      });
    }, observerOptions);
    
    document.querySelectorAll('[data-aos]').forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Nos essentiels"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
