{% comment %}
  Footer Section
{% endcomment %}

<footer class="footer" role="contentinfo">
  <div class="page-width">
    <div class="footer__content">
      <div class="footer__block footer__block--brand">
        <a href="{{ routes.root_url }}" class="footer__logo">
          {%- if settings.logo != blank -%}
            <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="150">
          {%- else -%}
            <span class="footer__logo-text">MONTRELLE</span>
          {%- endif -%}
        </a>
        <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {%- if settings.show_social_icons -%}
          <div class="footer__social">
            {%- if settings.social_instagram != blank -%}
              <a href="{{ settings.social_instagram }}" class="footer__social-link" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="2" width="20" height="20" rx="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="18" cy="6" r="1.5" fill="currentColor"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_facebook != blank -%}
              <a href="{{ settings.social_facebook }}" class="footer__social-link" aria-label="Facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_tiktok != blank -%}
              <a href="{{ settings.social_tiktok }}" class="footer__social-link" aria-label="TikTok">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_pinterest != blank -%}
              <a href="{{ settings.social_pinterest }}" class="footer__social-link" aria-label="Pinterest">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        <div class="footer__block" {{ block.shopify_attributes }}>
          <h3 class="footer__heading">{{ block.settings.heading | escape }}</h3>
          <ul class="footer__menu">
            {%- for link in block.settings.menu.links -%}
              <li class="footer__menu-item">
                <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}

      <div class="footer__block footer__block--newsletter">
        <h3 class="footer__heading">{{ section.settings.newsletter_heading }}</h3>
        <p class="footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
        {%- form 'customer', id: 'footer-newsletter', class: 'footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__newsletter-input-wrapper">
            <input type="email" 
                   name="contact[email]" 
                   class="footer__newsletter-input" 
                   placeholder="{{ section.settings.newsletter_placeholder }}"
                   required>
            <button type="submit" class="footer__newsletter-button">
              {{ section.settings.newsletter_button }}
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__payment">
        <span class="footer__payment-label">Paiement sécurisé</span>
        <div class="footer__payment-icons">
          <svg viewBox="0 0 48 32" width="40"><rect fill="#1A1F71" rx="4" width="48" height="32"/><path fill="#fff" d="M19 21h-3l2-12h3l-2 12zm8-12l-2.5 6.5-.5-3c-.5-2-2.5-3.5-4.5-3.5l3 9h3l4-9h-2.5zM17.5 9c-2 0-3.5 1-4 2.5l3.5 1c.5-1 1.5-1 2.5-1s2 .5 2 1.5c0 .5-.5 1-1.5 1h-2c-2 0-3.5 1-3.5 3s1.5 3 3.5 3c1 0 2-.5 2.5-1l.5 1h2.5l1.5-7.5c0-2.5-2-4-5-4z"/></svg>
          <svg viewBox="0 0 48 32" width="40"><rect fill="#EB001B" rx="4" width="48" height="32"/><circle cx="19" cy="16" r="10" fill="#F79E1B"/><path fill="#FF5F00" d="M24 8a10 10 0 0 1 0 16 10 10 0 0 1 0-16z"/></svg>
          <svg viewBox="0 0 48 32" width="40"><rect fill="#000" rx="4" width="48" height="32"/><text x="24" y="20" fill="#fff" font-size="10" font-weight="bold" text-anchor="middle">PayPal</text></svg>
          <svg viewBox="0 0 48 32" width="40"><rect fill="#FF5F00" rx="4" width="48" height="32"/><text x="24" y="20" fill="#fff" font-size="10" font-weight="bold" text-anchor="middle">iDEAL</text></svg>
        </div>
      </div>
      <div class="footer__copyright">
        <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.</p>
        <div class="footer__legal-links">
          <a href="/policies/legal-notice">Mentions légales</a>
          <a href="/policies/privacy-policy">Confidentialité</a>
          <a href="/policies/terms-of-service">CGV</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: var(--color-primary-light);
    padding: 6rem 0 2rem;
  }
  
  .footer__content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  
  @media screen and (max-width: 989px) {
    .footer__content {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }
  
  @media screen and (max-width: 749px) {
    .footer__content {
      grid-template-columns: 1fr;
    }
  }
  
  .footer__logo-text {
    font-family: var(--font-heading-family);
    font-size: 2.4rem;
    letter-spacing: 0.15em;
  }
  
  .footer__tagline {
    opacity: 0.7;
    margin: 1rem 0;
    font-size: 1.4rem;
  }
  
  .footer__social {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  
  .footer__social-link {
    color: var(--color-primary-light);
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  
  .footer__social-link:hover {
    opacity: 1;
  }
  
  .footer__heading {
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    font-weight: 500;
  }
  
  .footer__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer__menu-item {
    margin-bottom: 1rem;
  }
  
  .footer__menu-link {
    color: var(--color-primary-light);
    opacity: 0.7;
    text-decoration: none;
    font-size: 1.4rem;
    transition: opacity 0.2s;
  }
  
  .footer__menu-link:hover {
    opacity: 1;
  }
  
  .footer__newsletter-text {
    opacity: 0.7;
    font-size: 1.4rem;
    margin-bottom: 1.5rem;
  }
  
  .footer__newsletter-input-wrapper {
    display: flex;
    border-bottom: 1px solid rgba(255,255,255,0.3);
  }
  
  .footer__newsletter-input {
    flex: 1;
    background: none;
    border: none;
    color: var(--color-primary-light);
    padding: 1rem 0;
    font-size: 1.4rem;
  }
  
  .footer__newsletter-input::placeholder {
    color: rgba(255,255,255,0.5);
  }
  
  .footer__newsletter-button {
    background: none;
    border: none;
    color: var(--color-primary-light);
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 0;
  }
  
  .footer__bottom {
    padding-top: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }
  
  .footer__payment {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  
  .footer__payment-label {
    font-size: 1.3rem;
    opacity: 0.7;
  }
  
  .footer__payment-icons {
    display: flex;
    gap: 1rem;
  }
  
  .footer__copyright {
    display: flex;
    align-items: center;
    gap: 2rem;
    font-size: 1.3rem;
    opacity: 0.7;
  }
  
  .footer__legal-links {
    display: flex;
    gap: 1.5rem;
  }
  
  .footer__legal-links a {
    color: inherit;
    text-decoration: none;
  }
  
  .footer__legal-links a:hover {
    text-decoration: underline;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Élégance intemporelle pour femmes & hommes"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Restez informé"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Inscrivez-vous pour recevoir nos offres exclusives"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Newsletter Placeholder",
      "default": "Votre email"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Newsletter Button",
      "default": "S'inscrire"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Liens rapides"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Boutique",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Aide",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
