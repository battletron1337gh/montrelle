{% comment %}
  Footer - Modern minimalist
{% endcomment %}

<footer class="footer" role="contentinfo">
  <div class="footer__container">
    <div class="footer__main">
      <div class="footer__brand">
        <a href="{{ routes.root_url }}" class="footer__logo">
          {%- if settings.logo != blank -%}
            <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="140">
          {%- else -%}
            <span class="footer__logo-text">MONTRELLE</span>
          {%- endif -%}
        </a>
        <p class="footer__tagline">{{ section.settings.tagline | default: 'Élégance intemporelle pour femmes & hommes' }}</p>
        
        {%- if settings.show_social_icons -%}
          <div class="footer__social">
            {%- if settings.social_instagram != blank -%}
              <a href="{{ settings.social_instagram }}" class="footer__social-link" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="18" cy="6" r="1.5" fill="currentColor"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_facebook != blank -%}
              <a href="{{ settings.social_facebook }}" class="footer__social-link" aria-label="Facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_tiktok != blank -%}
              <a href="{{ settings.social_tiktok }}" class="footer__social-link" aria-label="TikTok">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        <div class="footer__column" {{ block.shopify_attributes }}>
          <h3 class="footer__heading">{{ block.settings.heading | escape }}</h3>
          <ul class="footer__menu">
            {%- for link in block.settings.menu.links -%}
              <li class="footer__menu-item">
                <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}

      <div class="footer__newsletter">
        <h3 class="footer__heading">{{ section.settings.newsletter_heading | default: 'Newsletter' }}</h3>
        <p class="footer__newsletter-text">{{ section.settings.newsletter_text | default: 'Inscrivez-vous pour recevoir nos offres exclusives' }}</p>
        {%- form 'customer', id: 'footer-newsletter', class: 'footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__newsletter-field">
            <input type="email" 
                   name="contact[email]" 
                   class="footer__newsletter-input" 
                   placeholder="{{ section.settings.newsletter_placeholder | default: 'Votre email' }}"
                   required>
            <button type="submit" class="footer__newsletter-button">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 10h12M12 6l4 4-4 4"/>
              </svg>
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.</p>
      <div class="footer__legal">
        <a href="/policies/legal-notice">Mentions légales</a>
        <a href="/policies/privacy-policy">Confidentialité</a>
        <a href="/policies/terms-of-service">CGV</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0a0a0a;
    color: rgba(255,255,255,0.8);
    padding: 8rem 0 3rem;
  }
  
  .footer__container {
    max-width: 140rem;
    margin: 0 auto;
    padding: 0 3rem;
  }
  
  .footer__main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: 5rem;
    padding-bottom: 5rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  
  @media screen and (max-width: 989px) {
    .footer__main {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }
  
  @media screen and (max-width: 749px) {
    .footer__main {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
  
  .footer__logo {
    display: inline-block;
    margin-bottom: 2rem;
  }
  
  .footer__logo-text {
    font-family: var(--font-heading-family);
    font-size: 2.2rem;
    letter-spacing: 0.2em;
    color: #fff;
  }
  
  .footer__tagline {
    font-size: 1.4rem;
    line-height: 1.7;
    opacity: 0.7;
    margin: 0 0 2.5rem;
    max-width: 30rem;
  }
  
  .footer__social {
    display: flex;
    gap: 1rem;
  }
  
  .footer__social-link {
    width: 4.2rem;
    height: 4.2rem;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: all 0.3s ease;
  }
  
  .footer__social-link:hover {
    background: #fff;
    color: #0a0a0a;
    border-color: #fff;
  }
  
  .footer__heading {
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 2rem;
    font-weight: 500;
  }
  
  .footer__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer__menu-item {
    margin-bottom: 1.2rem;
  }
  
  .footer__menu-link {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 1.4rem;
    transition: color 0.3s ease;
    position: relative;
  }
  
  .footer__menu-link:hover {
    color: #fff;
  }
  
  .footer__newsletter-text {
    font-size: 1.4rem;
    opacity: 0.7;
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  
  .footer__newsletter-field {
    display: flex;
    border-bottom: 1px solid rgba(255,255,255,0.3);
    transition: border-color 0.3s ease;
  }
  
  .footer__newsletter-field:focus-within {
    border-color: #fff;
  }
  
  .footer__newsletter-input {
    flex: 1;
    background: none;
    border: none;
    color: #fff;
    padding: 1.2rem 0;
    font-size: 1.4rem;
  }
  
  .footer__newsletter-input::placeholder {
    color: rgba(255,255,255,0.5);
  }
  
  .footer__newsletter-input:focus {
    outline: none;
  }
  
  .footer__newsletter-button {
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 0 1rem;
    transition: transform 0.3s ease;
  }
  
  .footer__newsletter-button:hover {
    transform: translateX(5px);
  }
  
  .footer__bottom {
    padding-top: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
    font-size: 1.3rem;
  }
  
  @media screen and (max-width: 749px) {
    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }
  
  .footer__copyright {
    opacity: 0.6;
    margin: 0;
  }
  
  .footer__legal {
    display: flex;
    gap: 2.5rem;
  }
  
  .footer__legal a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .footer__legal a:hover {
    color: #fff;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Élégance intemporelle pour femmes & hommes"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Inscrivez-vous pour recevoir nos offres exclusives"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Newsletter Placeholder",
      "default": "Votre email"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Liens rapides"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Boutique",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Aide",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
