{% comment %}
  Product Template
{% endcomment %}

<section class="product-section" data-section-type="product">
  <div class="page-width">
    <div class="product-grid">
      <!-- Product Images -->
      <div class="product-media">
        <div class="product-media__main">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 1200 }}"
                 alt="{{ product.featured_image.alt | escape }}"
                 class="product-media__image"
                 id="ProductMainImage"
                 loading="eager">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'product-media__image product-media__image--placeholder' }}
          {%- endif -%}
        </div>
        
        {%- if product.images.size > 1 -%}
          <div class="product-media__thumbnails">
            {%- for image in product.images -%}
              <button type="button" 
                      class="product-media__thumb{% if forloop.first %} product-media__thumb--active{% endif %}"
                      data-image="{{ image | image_url: width: 1200 }}"
                      data-alt="{{ image.alt | escape }}">
                <img src="{{ image | image_url: width: 200 }}"
                     alt="{{ image.alt | escape }}"
                     loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      
      <!-- Product Info -->
      <div class="product-info">
        <nav class="breadcrumbs">
          <a href="/">Accueil</a>
          <span class="breadcrumbs__separator">/</span>
          {%- if product.collections.first -%}
            <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
            <span class="breadcrumbs__separator">/</span>
          {%- endif -%}
          <span>{{ product.title }}</span>
        </nav>
        
        <h1 class="product-info__title">{{ product.title }}</h1>
        
        <div class="product-info__price">
          {%- if product.compare_at_price > product.price -%}
            <span class="product-info__price-sale">{{ product.price | money }}</span>
            <s class="product-info__price-compare">{{ product.compare_at_price | money }}</s>
            <span class="product-info__price-badge">-{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</span>
          {%- else -%}
            <span class="product-info__price-regular">{{ product.price | money }}</span>
          {%- endif -%}
        </div>
        
        <div class="product-info__description">
          {{ product.description }}
        </div>
        
        {%- form 'product', product, id: 'ProductForm', class: 'product-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          {%- unless product.has_only_default_variant -%}
            <div class="product-form__variants">
              {%- for option in product.options_with_values -%}
                <div class="product-form__option">
                  <label class="product-form__option-label">{{ option.name }}</label>
                  <div class="product-form__option-values">
                    {%- for value in option.values -%}
                      <label class="product-form__option-value">
                        <input type="radio" 
                               name="{{ option.name }}" 
                               value="{{ value }}"
                               {% if option.selected_value == value %}checked{% endif %}>
                        <span>{{ value }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}
          
          <div class="product-form__quantity">
            <label class="product-form__quantity-label">Quantité</label>
            <div class="quantity-selector">
              <button type="button" class="quantity-minus">-</button>
              <input type="number" name="quantity" value="1" min="1" max="99">
              <button type="button" class="quantity-plus">+</button>
            </div>
          </div>
          
          <div class="product-form__buttons">
            <button type="submit" 
                    name="add" 
                    class="product-form__add-button button"
                    {% unless product.available %}disabled{% endunless %}>
              {%- if product.available -%}
                Ajouter au panier
              {%- else -%}
                Épuisé
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}
        
        <div class="product-info__features">
          <div class="product-info__feature">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            <span>Livraison gratuite dès 50€</span>
          </div>
          <div class="product-info__feature">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            <span>Retour sous 30 jours</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .product-section {
    padding: 8rem 0;
  }
  
  .product-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    align-items: start;
  }
  
  @media screen and (max-width: 989px) {
    .product-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }
  
  .product-media__main {
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--color-background-dark);
    margin-bottom: 2rem;
  }
  
  .product-media__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .product-media__thumbnails {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
  }
  
  .product-media__thumb {
    width: 8rem;
    height: 10rem;
    border: 2px solid transparent;
    cursor: pointer;
    overflow: hidden;
    background: none;
    padding: 0;
    transition: border-color 0.3s ease;
  }
  
  .product-media__thumb--active {
    border-color: var(--color-primary);
  }
  
  .product-media__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .product-info {
    position: sticky;
    top: 10rem;
  }
  
  @media screen and (max-width: 989px) {
    .product-info {
      position: static;
    }
  }
  
  .product-info__title {
    font-size: clamp(2.8rem, 4vw, 3.6rem);
    margin: 1.5rem 0;
  }
  
  .product-info__price {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    font-size: 2rem;
  }
  
  .product-info__price-sale {
    font-weight: 500;
    color: #c41e3a;
  }
  
  .product-info__price-compare {
    opacity: 0.5;
    font-size: 1.6rem;
  }
  
  .product-info__price-badge {
    background: #c41e3a;
    color: #fff;
    padding: 0.4rem 1rem;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
  }
  
  .product-info__price-regular {
    font-weight: 500;
  }
  
  .product-info__description {
    font-size: 1.5rem;
    line-height: 1.8;
    opacity: 0.8;
    margin-bottom: 3rem;
  }
  
  .product-form__variants {
    margin-bottom: 2.5rem;
  }
  
  .product-form__option {
    margin-bottom: 2rem;
  }
  
  .product-form__option-label {
    display: block;
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  
  .product-form__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .product-form__option-value {
    cursor: pointer;
  }
  
  .product-form__option-value input {
    display: none;
  }
  
  .product-form__option-value span {
    display: block;
    padding: 1rem 2rem;
    border: 1px solid rgba(0,0,0,0.15);
    font-size: 1.4rem;
    transition: all 0.3s ease;
  }
  
  .product-form__option-value input:checked + span {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }
  
  .product-form__quantity {
    margin-bottom: 2.5rem;
  }
  
  .product-form__quantity-label {
    display: block;
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  
  .product-form__add-button {
    width: 100%;
    padding: 2rem;
    font-size: 1.4rem;
  }
  
  .product-form__add-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .product-info__features {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(0,0,0,0.1);
  }
  
  .product-info__feature {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.4rem;
    opacity: 0.7;
    margin-bottom: 1rem;
  }
</style>

<script>
  // Image switching
  document.querySelectorAll('.product-media__thumb').forEach(thumb => {
    thumb.addEventListener('click', function() {
      const mainImage = document.getElementById('ProductMainImage');
      mainImage.src = this.dataset.image;
      mainImage.alt = this.dataset.alt;
      
      document.querySelectorAll('.product-media__thumb').forEach(t => t.classList.remove('product-media__thumb--active'));
      this.classList.add('product-media__thumb--active');
    });
  });
  
  // Quantity selector
  document.querySelector('.quantity-minus')?.addEventListener('click', function() {
    const input = this.nextElementSibling;
    if (input.value > 1) input.value--;
  });
  
  document.querySelector('.quantity-plus')?.addEventListener('click', function() {
    const input = this.previousElementSibling;
    if (input.value < 99) input.value++;
  });
</script>
